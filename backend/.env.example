# ===========================================
# Railway Report Automation Platform - Backend
# Environment Configuration
# ===========================================

# Environment (set DEBUG=false in production)
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql://railway:railway@localhost:5432/railway

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Security - CHANGE IN PRODUCTION!
JWT_SECRET_KEY=dev-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CSRF Security - CHANGE IN PRODUCTION!
CSRF_SECRET_KEY=dev-csrf-secret-key-change-this

# Cookie Security
COOKIE_SECURE=false
COOKIE_SAMESITE=strict
COOKIE_HTTPONLY=true
COOKIE_DOMAIN=

# File Upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIRECTORY=uploads
ALLOWED_FILE_EXTENSIONS=[".xlsx", ".xls", ".csv"]

# CORS
CORS_ORIGINS=["http://127.0.0.1:5173", "http://localhost:5173"]

# External Services
REPORT_ENGINE_URL=http://127.0.0.1:8001
RULE_ENGINE_URL=http://127.0.0.1:8002

# Automation Engine (standalone Playwright service)
AUTOMATION_ENGINE_URL=http://127.0.0.1:8003
AUTOMATION_SERVICE_TOKEN=dev-automation-service-token-change-in-production
AUTOMATION_ENCRYPTION_KEY=
AUTOMATION_DOWNLOADS_DIR=downloads

# In-process browser automation (app/automation)
CHROME_DEBUG_URL=http://127.0.0.1:9222
DOWNLOAD_FOLDER=downloads
TIMEOUT=300
RETRY_COUNT=3
RAILMADAD_URL=https://railmadad.indianrail.gov.in

# RailMadad portal credentials (seed default profile)
RAILMADAD_USERNAME=
RAILMADAD_PASSWORD=
RAILMADAD_PORTAL_URL=https://railmadad.indianrail.gov.in

# Logging
LOG_LEVEL=INFO

# Default admin (created once on startup if user does not exist)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@123456

# API
API_PREFIX=/api/v1
