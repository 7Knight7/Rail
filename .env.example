# ===========================================
# Railway Report Automation Platform
# Environment Configuration
# ===========================================

# Environment
ENVIRONMENT=development
DEBUG=false

# Database
POSTGRES_USER=railway
POSTGRES_PASSWORD=railway
POSTGRES_DB=railway
DATABASE_URL=postgresql://railway:railway@localhost:5432/railway

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Security - CHANGE IN PRODUCTION!
JWT_SECRET_KEY=dev-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CSRF Security - CHANGE IN PRODUCTION!
CSRF_SECRET_KEY=dev-csrf-secret-key-change-this

# Cookie Security
COOKIE_SECURE=false
COOKIE_SAMESITE=strict
COOKIE_HTTPONLY=true

# File Upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIRECTORY=uploads
ALLOWED_FILE_EXTENSIONS=[".xlsx", ".xls", ".csv"]

# CORS
CORS_ORIGINS=["http://127.0.0.1:5173", "http://localhost:5173"]

# Logging
LOG_LEVEL=INFO

# Default admin (created once on startup if user does not exist)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@123456

# API
API_PREFIX=/api/v1

# Frontend dev server (Vite strictPort — do not change unless intentional)
# VITE dev URL: http://127.0.0.1:5173
# Backend API: http://127.0.0.1:8000 (proxied via /api in development)
# VITE_API_BASE_URL=/api/v1
